# ============================================================================
# REC - Music Recommendation Platform
# Environment Variables Template
# ============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================================================
# Database Configuration (Prisma)
# ============================================================================

# Transaction pooler connection (for application queries)
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true&statement_cache_size=0"

# Direct connection (for Prisma migrations/introspection)
DIRECT_URL="postgresql://user:password@host:5432/database"

# ============================================================================
# NextAuth.js Configuration
# ============================================================================

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"  # openssl rand -base64 32

# ============================================================================
# OAuth Providers
# ============================================================================

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Spotify OAuth (also used for Spotify API)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"

# ============================================================================
# Redis Configuration (BullMQ Queue System)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Uncomment if Redis requires authentication
# REDIS_URL=redis://localhost:6379/0  # Alternative to individual host/port settings
# REDIS_CACHE_ENABLED=true  # Set to "false" to bypass Redis cache (all reads miss, no writes)

# ============================================================================
# Cloudflare Images Configuration
# ============================================================================

CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token
CLOUDFLARE_IMAGES_ACCOUNT_HASH=your-account-hash
CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net/your-account-hash
NEXT_PUBLIC_CLOUDFLARE_IMAGES_DELIVERY_URL=https://imagedelivery.net/your-account-hash

# ============================================================================
# Last.fm API (Optional - for additional music metadata)
# ============================================================================

LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=your-lastfm-api-secret

# Last.fm User Sync Scheduler
LASTFM_SYNC_ENABLED=true                   # Enable/disable user data sync scheduler
LASTFM_SYNC_INTERVAL_MINUTES=10080         # Dispatch interval (default: 7 days)

# ============================================================================
# Feature Flags
# ============================================================================

# Enable mosaic editor feature
NEXT_PUBLIC_ENABLE_MOSAIC_EDITOR=false

# Enable record collection editing (drag-and-drop, resizing)
NEXT_PUBLIC_ENABLE_COLLECTION_EDITOR=false

# Admin Overlay - Toggle admin UI features (admin actions, debug info)
NEXT_PUBLIC_ADMIN_OVERLAY=false

# Admin email for special permissions
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Axiom log aggregation (optional — enables structured log search in production)
# Sign up at https://axiom.co (free: 500 GB/month, 30-day retention)
# AXIOM_DATASET=rec-logs
# AXIOM_TOKEN=xaat-your-api-token

# ============================================================================
# MusicBrainz Scheduler Configuration
# ============================================================================

# Enable/disable MusicBrainz new releases sync
MUSICBRAINZ_SYNC_NEW_RELEASES=true

# Sync frequency in minutes (10080 = 7 days)
MUSICBRAINZ_NEW_RELEASES_INTERVAL_MINUTES=10080

# Number of releases to fetch per sync
MUSICBRAINZ_NEW_RELEASES_LIMIT=50

# ============================================================================
# ListenBrainz Fresh Releases Sync
# ============================================================================

# Enable/disable ListenBrainz fresh releases sync (state persists in database)
# Uses the public ListenBrainz API — no auth required
LISTENBRAINZ_SYNC_FRESH_RELEASES=true

# Sync interval in minutes (default: 10080 = 7 days)
LISTENBRAINZ_SYNC_INTERVAL_MINUTES=10080

# Lookback window in days (1-90, default: 14)
LISTENBRAINZ_SYNC_DAYS=14

# Include future releases (default: true)
LISTENBRAINZ_SYNC_INCLUDE_FUTURE=true

# Primary release types to sync (comma-separated, default: Album,EP,Single)
# Releases with secondary types (Compilation, Live, Remix, etc.) are excluded automatically
LISTENBRAINZ_SYNC_PRIMARY_TYPES=Album,EP,Single

# Minimum listen count on ListenBrainz to include a release (default: 0 = no filter)
# ListenBrainz returns thousands of releases, most with 0 listens.
# Set this to filter out obscure releases (e.g., 5 = only releases with 5+ listens)
LISTENBRAINZ_SYNC_MIN_LISTEN_COUNT=0

# Maximum number of releases to process per sync (default: 0 = no limit)
# ListenBrainz can return 3000+ releases in a 14-day window.
# Set this to cap each sync batch (e.g., 50 = process top 50 releases only)
LISTENBRAINZ_SYNC_MAX_RELEASES=50

# Minimum unique listeners on the primary artist (from ListenBrainz Popularity API)
# Releases by artists with fewer unique listeners are filtered out.
# Set to 0 to disable artist popularity filtering.
# NOTE: DB values (set via admin UI) override these env vars when set.
LISTENBRAINZ_SYNC_MIN_ARTIST_LISTENERS=1000

# ============================================================================
# Cloudflare D1 Game Album Lookup (Uncover autocomplete)
# ============================================================================

# Worker URL for game album search (deployed via `npx wrangler deploy --config cloudflare/wrangler.toml`)
GAME_LOOKUP_WORKER_URL=https://game-album-lookup.your-subdomain.workers.dev

# ============================================================================
# Google Cloud Vision API (Uncover text detection)
# ============================================================================

# Option 1: Path to service account JSON key file
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"

# Option 2: JSON content of service account key (for Railway/cloud deployments)
# GOOGLE_CLOUD_VISION_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"..."}'

# ============================================================================
# Task Master AI Configuration (Development Tool)
# ============================================================================

# API Keys for AI providers (only needed if using Task Master)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"       # Required: Format: sk-ant-api03-...
PERPLEXITY_API_KEY="your_perplexity_api_key_here"     # Optional: Format: pplx-...
OPENAI_API_KEY="your_openai_api_key_here"             # Optional: Format: sk-proj-...
